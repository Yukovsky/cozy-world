# Выходные файлы сборки
/build/
/dist/

# Покрытие тестами
/coverage/

# Генерируемый код (Firebase, JSON сериализаторы, protobuf и т.д.)
# Примечание: Некоторые генераторы могут нужно хранить; отрегулируйте по необходимости
**/generated/
lib/generated/

# Документация
/doc/api/

# Платформо-специфичные директории сборки (храните в репо для воспроизводимости + CI)
# Раскомментируйте только если хотите их исключить полностью
# /android/
# /ios/
# /linux/
# /macos/
# /windows/
# /web/

# Android-специфичные артефакты сборки (безопасно игнорировать)
android/app/debug/
android/app/profile/
android/app/release/

# === ОКРУЖЕНИЕ И СЕКРЕТЫ (КРИТИЧНО) ===
# Никогда не коммитьте реальные файлы окружения — используйте .example шаблоны
.env
.env.local
.env.*.local
lib/config/.env

# Android keystore и параметры подписи
# ВАЖНО: Всегда генерируйте локально из android/key.properties.example
android/key.properties
android/**/*.keystore
android/**/*.jks
*.keystore
*.jks

# Файлы конфигурации Firebase (если используется)
google-services.json
GoogleService-Info.plist

# === ПЛАТФОРМО/CI СПЕЦИФИЧНОЕ ===
# Gradle
.gradle/
gradle-wrapper.jar (опционально — обычно безопасно включить)

# Xcode
xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/

# iOS
Pods/
Podfile.lock

